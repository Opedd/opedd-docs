    "/registry": {
      "get": {
        "operationId": "browseRegistry",
        "tags": ["Registry"],
        "summary": "Registry of Proof",
        "description": "Browse the public Registry of Proof — the immutable, on-chain verified record of all licenses issued through Opedd. **Public — no API key required.**\n\nFilter by license key, article, or publisher. Without filters, returns a global feed of recent licenses.",
        "parameters": [
          {
            "name": "license_key",
            "in": "query",
            "schema": { "$ref": "#/components/schemas/LicenseKey" },
            "description": "Filter to a specific license key"
          },
          {
            "name": "article_id",
            "in": "query",
            "schema": { "type": "string", "format": "uuid" },
            "description": "Filter by article"
          },
          {
            "name": "publisher_id",
            "in": "query",
            "schema": { "type": "string", "format": "uuid" },
            "description": "Filter by publisher"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": { "type": "integer", "default": 20, "maximum": 100 }
          },
          {
            "name": "offset",
            "in": "query",
            "schema": { "type": "integer", "default": 0 }
          }
        ],
        "responses": {
          "200": {
            "description": "Registry entries",
            "content": {
              "application/json": {
                "example": {
                  "success": true,
                  "data": {
                    "records": [
                      {
                        "license_key": "OP-A1B2-C3D4",
                        "license_type": "ai",
                        "article_title": "The Future of AI in Newsrooms",
                        "publisher_name": "The Daily Record",
                        "licensee_organization": "Acme AI Corp",
                        "amount": 50.00,
                        "issued_at": "2026-03-06T12:00:00Z",
                        "blockchain_status": "confirmed",
                        "blockchain_tx_hash": "0xabc123..."
                      }
                    ],
                    "total": 1,
                    "limit": 20,
                    "offset": 0
                  }
                }
              }
            }
          }
        }
      }
    },
    "/license-discovery": {
      "get": {
        "operationId": "licenseDiscovery",
        "tags": ["Agent"],
        "summary": "License discovery",
        "description": "Returns a machine-readable `opedd.json` discovery file for a publisher. AI agents and crawlers use this to discover what content is available for licensing, current pricing, and how to purchase programmatically.\n\nEquivalent to a `robots.txt` for AI licensing.",
        "parameters": [
          {
            "name": "publisher_id",
            "in": "query",
            "schema": { "type": "string", "format": "uuid" },
            "description": "Publisher UUID"
          },
          {
            "name": "domain",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Publisher domain (alternative to publisher_id)",
            "example": "publisher.com"
          }
        ],
        "responses": {
          "200": {
            "description": "Publisher discovery file",
            "content": {
              "application/json": {
                "example": {
                  "protocol": "opedd",
                  "version": "1.0",
                  "publisher": {
                    "id": "6973a2e9-dee6-4797-a6cb-c927952374e6",
                    "name": "The Daily Record",
                    "website": "https://publisher.com"
                  },
                  "catalog": {
                    "total_articles": 816,
                    "licensed_articles": 802
                  },
                  "pricing": {
                    "default_human": 10.00,
                    "default_ai": 50.00,
                    "currency": "usd"
                  },
                  "endpoints": {
                    "lookup": "https://djdzcciayennqchjgybx.supabase.co/functions/v1/lookup-article",
                    "purchase": "https://djdzcciayennqchjgybx.supabase.co/functions/v1/agent-purchase",
                    "verify": "https://djdzcciayennqchjgybx.supabase.co/functions/v1/api?action=verify",
                    "registry": "https://djdzcciayennqchjgybx.supabase.co/functions/v1/registry"
                  },
                  "agent_instructions": "Use the lookup endpoint to check if an article is licensable. Then use agent-purchase with a Stripe payment method or USDC transaction to obtain a license key."
                }
              }
            }
          }
        }
      }
    },
    "/certificate": {
      "get": {
        "operationId": "getCertificate",
        "tags": ["Licenses"],
        "summary": "Download certificate (PDF)",
        "description": "Download a PDF license certificate for a given license key. **Public — no API key required.**",
        "parameters": [
          {
            "name": "key",
            "in": "query",
            "required": true,
            "schema": { "$ref": "#/components/schemas/LicenseKey" },
            "description": "License key"
          }
        ],
        "responses": {
          "200": {
            "description": "PDF certificate",
            "content": {
              "application/pdf": {}
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/invoice": {
      "get": {
        "operationId": "getInvoice",
        "tags": ["Licenses"],
        "summary": "Download invoice (PDF)",
        "description": "Download a PDF invoice for a completed license purchase. Includes Bill From/To, issue date, Net-30 due date, archive coverage period, and PAID/PENDING status. **Public — no API key required.**",
        "parameters": [
          {
            "name": "key",
            "in": "query",
            "required": true,
            "schema": { "$ref": "#/components/schemas/LicenseKey" },
            "description": "License key"
          }
        ],
        "responses": {
          "200": {
            "description": "PDF invoice",
            "content": {
              "application/pdf": {}
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/ai-defense-policy": {
      "get": {
        "operationId": "aiDefensePolicy",
        "tags": ["Publisher"],
        "summary": "AI crawler policy",
        "description": "Generate a `robots.txt` or `ai.txt` blocking file for a publisher. Blocks 16 known AI crawlers including GPTBot, ClaudeBot, Googlebot-Extended, and more.\n\nServe this from your site at `/robots.txt` or `/ai.txt` to enforce your licensing policy against AI scrapers.",
        "parameters": [
          {
            "name": "publisher_id",
            "in": "query",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          },
          {
            "name": "format",
            "in": "query",
            "schema": { "type": "string", "enum": ["robots", "ai"], "default": "robots" },
            "description": "`robots` returns robots.txt format. `ai` returns ai.txt format."
          }
        ],
        "responses": {
          "200": {
            "description": "Crawler policy file",
            "content": {
              "text/plain": {
                "example": "User-agent: GPTBot\nDisallow: /\n\nUser-agent: ClaudeBot\nDisallow: /\n\n# Licensed via Opedd — opedd.com"
              }
            }
          }
        }
      }
    },
    "/resend-licenses": {
      "post": {
        "operationId": "resendLicenses",
        "tags": ["Licenses"],
        "summary": "Resend license keys",
        "description": "Re-send all license keys associated with an email address in a single consolidated email. Useful if a buyer lost their keys.\n\n**Rate limit:** 3 requests per email per hour.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email"],
                "properties": {
                  "email": { "type": "string", "format": "email" }
                }
              },
              "example": { "email": "buyer@example.com" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Email sent",
            "content": {
              "application/json": {
                "example": { "success": true, "data": { "sent": true, "count": 3 } }
              }
            }
          },
          "429": { "$ref": "#/components/responses/RateLimited" }
        }
      }
    }
  },
  "x-scalar-theme": "default"
}
